NEXT_PUBLIC_APP_NAME=Play Harmonium
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DESCRIPTION=Free web harmonium for browser-based practice.
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_LOCALE_DETECT_ENABLED=false

DATABASE_PROVIDER=postgresql
DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/harmonium

AUTH_URL=http://localhost:3000
AUTH_SECRET=replace-with-a-random-secret

DB_SCHEMA_FILE=./src/config/db/schema.ts
DB_MIGRATIONS_OUT=./src/config/db/migrations
DB_MIGRATIONS_SCHEMA=drizzle
DB_MIGRATIONS_TABLE=__drizzle_migrations
DB_SCHEMA=public
DB_SINGLETON_ENABLED=false
DB_MAX_CONNECTIONS=1
